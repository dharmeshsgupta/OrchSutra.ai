# ═══════════════════════════════════════════════════════════════════════
#  ROOT .env.example — Safe template to commit to Git
#  Copy this file to .env and fill in your real values.
#
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────
#  PostgreSQL Database
# ─────────────────────────────────────
POSTGRES_USER=orchsutra
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=openrouter

# In Docker: @postgres (service name). In local dev: @localhost
DATABASE_URL=postgresql+asyncpg://orchsutra:change_me_strong_password@postgres:5432/openrouter

# ─────────────────────────────────────
#  Firebase Admin (primary-backend)
# ─────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_KEY=./openrouter-51e78-firebase-adminsdk-fbsvc-a8d3902ad5.json

# ─────────────────────────────────────
#  JWT
# ─────────────────────────────────────
JWT_SECRET=change_me_at_least_32_chars_long

# ─────────────────────────────────────
#  LLM Provider API Keys
# ─────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_API_BASE=https://api.openai.com/v1

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_BASE=https://api.anthropic.com/v1

GEMINI_API_KEY=AIza...

GROQ_API_KEY=gsk_...

DEEPSEEK_API_KEY=sk-...

MISTRAL_API_KEY=

SARVAM_API_KEY=sk_...
SARVAM_API_BASE=https://api.sarvam.ai/v1

# ─────────────────────────────────────
#  NVIDIA APIs
# ─────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_MAGPIE_FUNCTION_ID=your-function-id
NVIDIA_MAGPIE_URI=grpc.nvcf.nvidia.com:443

# ─────────────────────────────────────
#  Media (Image + Audio)
# ─────────────────────────────────────
MEDIA_IMAGE_API_KEY=nvapi-...
MEDIA_IMAGE_API_BASE=https://ai.api.nvidia.com/v1
MEDIA_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b
MEDIA_VISION_MODEL=gpt-4o-mini
MEDIA_IMAGE_FALLBACK_API_KEY=
MEDIA_IMAGE_FALLBACK_API_BASE=
MEDIA_IMAGE_FALLBACK_MODEL=
MEDIA_VISION_FALLBACK_MODEL=

MEDIA_AUDIO_API_KEY=
MEDIA_AUDIO_API_BASE=https://api.openai.com/v1
MEDIA_AUDIO_MODEL=gpt-4o-mini-tts
MEDIA_AUDIO_FILES_DIR=static/audio

# ─────────────────────────────────────
#  Chat Defaults
# ─────────────────────────────────────
CHAT_DEFAULT_MODEL_ID=groq-llama-3.3-70b
CHAT_MODEL_OPTIONS=[]

# ─────────────────────────────────────
#  Agent Engine
# ─────────────────────────────────────
LLM_ROUTER_BASE_URL=http://api-backend:3000
ROUTER_CHAT_PATH=/chat/completions
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001
ENGINE_MEMORY_DB_PATH=./.engine/memory.sqlite3
ENGINE_VECTORSTORE_PATH=./.engine/vectorstore

# ─────────────────────────────────────
#  Internal Tokens
# ─────────────────────────────────────
API_BACKEND_URL=http://api-backend:3000
API_BACKEND_TOKEN=change_me_shared_token

# ─────────────────────────────────────
#  Firebase Web SDK (Frontend)
# ─────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
