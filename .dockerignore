# ─────────────────────────────────────────────────────────────
#  .dockerignore  ──  "Tell Docker what to ignore"
#
#  LESSON: What is .dockerignore?
#  Just like .gitignore tells Git what NOT to track,
#  .dockerignore tells Docker what NOT to copy into the image.
#
#  Why does this matter?
#  When Docker builds an image, it sends ALL files in the
#  "context" folder to the Docker daemon. If you have
#  node_modules (100,000+ files) or .venv, this can take
#  minutes and bloat your image. We exclude them here.
# ─────────────────────────────────────────────────────────────

# Python virtual environments
.venv
venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache

# Node.js (frontend only — but safe to put at root level)
node_modules
npm-debug.log

# Build artifacts (we build fresh inside Docker)
dist
build
*.egg-info

# Git files (not needed inside container)
.git
.gitignore

# IDE and OS files
.vscode
.idea
*.DS_Store
Thumbs.db

# Environment files
# NOTE: We DO copy .env files in our Dockerfiles for development.
# Uncomment the next line in PRODUCTION and use Docker secrets instead.
# .env

# Test files
*.test.py
test_*.py

# Logs
*.log
